<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.investment.controller.MainController"
            style="-fx-background-color: #1e1e2e;">

    <!-- Верхняя панель заголовка -->
    <top>
        <HBox style="-fx-background-color: #313244; -fx-padding: 12 20; -fx-spacing: 20;"
              alignment="CENTER_LEFT">
            <Label text="Инвестиционный портфель"
                   style="-fx-text-fill: #cdd6f4; -fx-font-size: 20; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="totalLabel"
                   style="-fx-text-fill: #a6e3a1; -fx-font-size: 16; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Таблица активов -->
    <center>
        <TableView fx:id="assetsTable"
                   style="-fx-background-color: #1e1e2e; -fx-table-cell-border-color: #313244;"
                   BorderPane.margin="$padding">
            <columns>
                <TableColumn fx:id="colName"         text="Название"        prefWidth="140"/>
                <TableColumn fx:id="colTicker"       text="Тикер"           prefWidth="80"/>
                <TableColumn fx:id="colQuantity"     text="Кол-во"          prefWidth="80"/>
                <TableColumn fx:id="colBuyPrice"     text="Цена покупки"    prefWidth="110"/>
                <TableColumn fx:id="colCurrentPrice" text="Текущая цена"    prefWidth="110"/>
                <TableColumn fx:id="colValue"        text="Стоимость"       prefWidth="110"/>
                <TableColumn fx:id="colGain"         text="Прибыль ₽"       prefWidth="100"/>
                <TableColumn fx:id="colGainPercent"  text="Прибыль %"       prefWidth="100"/>
            </columns>
            <BorderPane.margin>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </BorderPane.margin>
        </TableView>
    </center>

    <!-- Нижняя панель: кнопки и статус -->
    <bottom>
        <HBox style="-fx-background-color: #181825; -fx-padding: 8 20; -fx-spacing: 10;"
              alignment="CENTER_LEFT">
            <Button fx:id="btnAdd"    text="+ Добавить" onAction="#onAddAsset"
                    style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
            <Button fx:id="btnRemove" text="− Удалить"  onAction="#onRemoveAsset"
                    style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Готово"
                   style="-fx-text-fill: #a6e3a1; -fx-font-size: 13;"/>
        </HBox>
    </bottom>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.investment.controller.OrderBookController"
            style="-fx-background-color: #1e1e2e;"
            prefWidth="880" prefHeight="620">

    <top>
        <VBox style="-fx-background-color: #313244; -fx-padding: 12 20;" spacing="10">
            <Label text="Торговый стакан: демонстрация race condition"
                   style="-fx-text-fill: #cdd6f4; -fx-font-size: 18; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Реализация:" style="-fx-text-fill: #cdd6f4;"/>
                <ComboBox fx:id="implCombo" prefWidth="280"/>

                <Label text="Пул:" style="-fx-text-fill: #cdd6f4;"/>
                <Spinner fx:id="poolSpinner"    prefWidth="70"/>

                <Label text="Клиентов:" style="-fx-text-fill: #cdd6f4;"/>
                <Spinner fx:id="clientsSpinner" prefWidth="70"/>

                <Label text="Купить каждому:" style="-fx-text-fill: #cdd6f4;"/>
                <Spinner fx:id="targetSpinner"  prefWidth="70"/>

                <Label text="Чанк:" style="-fx-text-fill: #cdd6f4;"/>
                <Spinner fx:id="chunkSpinner"   prefWidth="70"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="▶ Запустить"       onAction="#onRun"
                        style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
                <Button text="⏩ Прогнать 20 раз" onAction="#onBatch"
                        style="-fx-background-color: #fab387; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
                <Button text="⟳ Сбросить"        onAction="#onReset"
                        style="-fx-background-color: #f9e2af; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="batchLabel"
                       style="-fx-text-fill: #f38ba8; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="0">
            <!-- Левая колонка: счётчики -->
            <VBox style="-fx-background-color: #181825; -fx-padding: 20; -fx-spacing: 10;"
                  prefWidth="260">
                <Label text="Состояние пула"
                       style="-fx-text-fill: #cdd6f4; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Separator/>
                <Label text="Осталось:"  style="-fx-text-fill: #bac2de;"/>
                <Label fx:id="availLabel"
                       style="-fx-text-fill: #89b4fa; -fx-font-size: 28; -fx-font-weight: bold;"/>
                <Label text="Продано:"   style="-fx-text-fill: #bac2de;"/>
                <Label fx:id="soldLabel"
                       style="-fx-text-fill: #a6e3a1; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <Label text="ПЕРЕТОРГОВАНО:" style="-fx-text-fill: #bac2de;"/>
                <Label fx:id="oversoldLabel"
                       style="-fx-text-fill: #f38ba8; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <Separator/>
                <Label text="Клиенты" style="-fx-text-fill: #cdd6f4; -fx-font-weight: bold;"/>
                <Label fx:id="clientsStatus" wrapText="true"
                       style="-fx-text-fill: #cdd6f4; -fx-font-family: 'Menlo', 'Consolas', monospace;"/>
            </VBox>

            <!-- Правая колонка: лог -->
            <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
                <Label text="Журнал событий (нижние — свежие)"
                       style="-fx-text-fill: #cdd6f4; -fx-font-weight: bold;">
                    <padding><Insets bottom="4"/></padding>
                </Label>
                <ListView fx:id="logView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #11111b; -fx-text-fill: #cdd6f4; -fx-font-family: 'Menlo', 'Consolas', monospace; -fx-font-size: 12;"/>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #181825; -fx-padding: 8 20;"
              alignment="CENTER_LEFT">
            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #a6e3a1; -fx-font-size: 13;"/>
        </HBox>
    </bottom>

</BorderPane>
